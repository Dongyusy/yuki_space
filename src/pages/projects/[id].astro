---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/portfolio";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path = "") => `${basePath}${path.replace(/^\/+/, "")}`;
---

<BaseLayout title={`${project.title} | Yuki Portfolio`} description={project.summary}>
  <main class="project-detail">
    <header class="project-detail-header section-shell">
      <a class="back-link" href={withBase("#projects")}>Back to Projects</a>
      <p class="eyebrow">{project.year} / {project.category}</p>
      <h1>{project.title}</h1>
      <p class="intro">{project.summary}</p>
      <div class="tag-list detail-tags">
        {
          project.tags.map((tag) => (
            <span>{tag}</span>
          ))
        }
      </div>
    </header>

    <section class="project-gallery section-shell" aria-label={`${project.title} gallery`}>
      {
        project.images.map((image, index) => (
          <figure class="project-image">
            <img src={image} alt={`${project.title} ${index + 1}`} loading={index === 0 ? "eager" : "lazy"} />
          </figure>
        ))
      }
    </section>
  </main>
</BaseLayout>
