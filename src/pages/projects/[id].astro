---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/portfolio";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout title={`${project.title} | Yuki Portfolio`} description={project.summary} hideHeader>
  <main class="project-detail">
    <section class="project-gallery" aria-label={`${project.title} gallery`}>
      {
        project.images.map((image, index) => (
          <figure class="project-image">
            <img src={image} alt={`${project.title} ${index + 1}`} loading={index === 0 ? "eager" : "lazy"} />
          </figure>
        ))
      }
    </section>
  </main>
</BaseLayout>
